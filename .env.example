# Base URL of the real backend API. When unset, the app runs against the
# built-in in-browser mock backend (src/backend/handlers.ts).
#
# Local development against the real server (server/index.ts):
#   1. npm run api          (starts the API on http://localhost:4000)
#   2. VITE_API_URL=/api npm run dev
# Vite proxies /api/* to :4000 (see vite.config.ts), so no CORS setup
# is needed. Pointing at a deployed server also works:
# VITE_API_URL=https://api.kre8trix.app
# VITE_API_URL=/api

# ── API server (server/index.ts) configuration ──
# KRE8TRIX_JWT_SECRET=change-me-in-production   # HMAC secret; random per boot when unset
# KRE8TRIX_DATA_DIR=server/.data                # where per-account state + users live
# KRE8TRIX_DEMO=0                               # disable auto-provisioning logins
# KRE8TRIX_EPHEMERAL=1                          # in-memory only (tests/demos)
# PORT=4000
